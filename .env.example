FLASK_ENV=development
SECRET_KEY=replace_me
WORDBEE_PASSWORD_HASH=replace_me
DATABASE_PATH=data/wordbee.sqlite
WORDBEE_PUZZLE_TIMEZONE=America/Chicago
WORDBEE_ENABLE_ARTICLE_CORROBORATORS=0
